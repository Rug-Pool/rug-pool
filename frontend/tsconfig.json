{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$store/*": ["./src/store/*"],
      "$hooks/*": ["./src/hooks/*"],
      "$components/*": ["./src/components/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
